# Replit
.cache/
.local/

# Generated runtime artifacts
data/uploads/documents/*.pdf
# version.json is regenerated by scripts/generate-version.mjs (predev/prebuild
# hooks) with the real git commit count/hash, but a minimal fallback copy is
# intentionally committed to git (force-added) so the app never hard-fails a
# build/dev start in an environment where those hooks didn't run (fresh clone,
# container restart, a start command that bypasses npm/pnpm script lifecycle).
# This pattern means `git status` will show these files as modified after any
# real build/dev run — that's expected, not a bug; don't sweep them into an
# unrelated commit.
artifacts/*/src/generated/version.json

# Prompt paste files (auto-created by Replit when pasting into chat)
attached_assets/*.txt
artifacts/api-server/src/lib/workflow-executor.ts
CLAUDE.md
artifacts/shane-mccaw-consulting/public/sitemap.xml 
