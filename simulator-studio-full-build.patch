+    return res.json({ token });
+  } catch (err) {
+    logger.error({ err, customerId }, "admin-engines: portal-mirror-token failed");
+    return res.status(500).json({ error: err instanceof Error ? err.message : "Failed to issue portal mirror token" });
+  }
+});
