modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 20130
externalPort = 3002

[[ports]]
localPort = 20446
externalPort = 80

[[ports]]
localPort = 22444
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
RESEND_FROM = "Shane McCaw Consulting <onboarding@resend.dev>"
