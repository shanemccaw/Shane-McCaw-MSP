    "@replit/connectors-sdk": "^0.4.1",
    "@simplewebauthn/server": "^13.3.1",
    "@types/multer": "^2.1.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "ajv": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "playwright-core": "^1.61.1",
    "qrcode": "^1.5.4",
    "resend": "^6.14.0",
    "stripe": "catalog:",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "esbuild": "0.27.3",
