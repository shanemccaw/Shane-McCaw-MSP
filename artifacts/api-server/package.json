{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development PORT=${PORT:-8080} && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run && node --experimental-strip-types --experimental-test-module-mocks --test 'src/lib/stripe.test.ts' 'src/lib/ps-guard.test.ts' 'src/lib/kanban-auto-fire-routing.test.ts' 'src/routes/admin-ps-scripts.test.ts' 'src/routes/admin-ps-scripts-modularize.test.ts' 'src/routes/leads-stats.test.ts' 'src/routes/opportunities.test.ts' 'src/routes/portal-lp-token-gate.test.ts' 'src/routes/admin-script-runner.test.ts' 'src/routes/portal-scope-sync.test.ts' 'src/routes/portal-scope-toggle.test.ts' 'src/routes/portal-checkout-price.test.ts' 'src/routes/portal-presentation-webhook.test.ts' 'src/routes/portal-payment-webhook-idempotency.test.ts' 'src/routes/portal-sow-version.test.ts' 'src/routes/portal-sow-sse.test.ts' && node --experimental-strip-types --test 'src/lib/kanban-auto-fire-retry-budget.test.ts'",
    "seed-marketing": "node --enable-source-maps ./dist/scripts/seed-marketing.mjs"
  },
  "dependencies": {
    "@azure/arm-automation": "^10.1.1",
    "@azure/identity": "^4.13.1",
